{
  "easycom": {
    "autoscan": true,
    "custom": {
      "^post-card$": "@/components/post-card.vue"
    }
  },
  "pages": [
    {
      "path": "pages/feed/index",
      "style": {
        "navigationBarTitleText": "MATCHit",
        "navigationStyle": "default",
        "enablePullDownRefresh": true
      }
    },
    {
      "path": "pages/messages/index",
      "style": {
        "navigationBarTitleText": "消息",
        "enablePullDownRefresh": true
      }
    },
    {
      "path": "pages/chat/index",
      "style": {
        "navigationBarTitleText": "私信"
      }
    },
    {
      "path": "pages/chat/room",
      "style": {
        "navigationBarTitleText": "聊天"
      }
    },
    {
      "path": "pages/profile/index",
      "style": {
        "navigationBarTitleText": "我"
      }
    },
    {
      "path": "pages/post/detail",
      "style": {
        "navigationBarTitleText": "组局详情",
        "enablePullDownRefresh": true
      }
    },
    {
      "path": "pages/publish/index",
      "style": {
        "navigationBarTitleText": "发布组局"
      }
    },
    {
      "path": "pages/login/index",
      "style": {
        "navigationBarTitleText": "登录"
      }
    }
  ],
  "globalStyle": {
    "navigationBarTextStyle": "black",
    "navigationBarTitleText": "MATCHit",
    "navigationBarBackgroundColor": "#FFFFFF",
    "backgroundColor": "#F2F2F7"
  },
  "tabBar": {
    "color": "#999999",
    "selectedColor": "#002FA7",
    "backgroundColor": "#FFFFFF",
    "borderStyle": "black",
    "list": [
      {
        "pagePath": "pages/feed/index",
        "text": "首页",
        "iconPath": "static/tab/home.png",
        "selectedIconPath": "static/tab/home-active.png"
      },
      {
        "pagePath": "pages/messages/index",
        "text": "消息",
        "iconPath": "static/tab/msg.png",
        "selectedIconPath": "static/tab/msg-active.png"
      },
      {
        "pagePath": "pages/chat/index",
        "text": "私信",
        "iconPath": "static/tab/chat.png",
        "selectedIconPath": "static/tab/chat-active.png"
      },
      {
        "pagePath": "pages/profile/index",
        "text": "我",
        "iconPath": "static/tab/me.png",
        "selectedIconPath": "static/tab/me-active.png"
      }
    ]
  }
}
