# 复制为 backend/api/.env 或直接 export
DATABASE_URL=postgres://matchit:matchit@localhost:5432/matchit?sslmode=disable
REDIS_URL=redis://localhost:6379/0
PORT=8080
JWT_SECRET=change-me-to-local-dev-secret
JWT_GUEST_TTL_HOURS=720
JWT_MEMBER_TTL_HOURS=168
REFRESH_TOKEN_TTL_HOURS=720
SMS_MOCK=true
SMS_CODE_TTL_MINUTES=5
SMS_RESEND_COOLDOWN_SECONDS=60
SMS_MAX_VERIFY_FAIL=5

# FCM 推送（Android）：Firebase 服务账号 JSON 单行，或设置 GOOGLE_APPLICATION_CREDENTIALS 路径
# FCM_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
